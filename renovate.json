{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "group:allNonMajor", "schedule:weekly"],
  "labels": ["dependencies"],
  "minimumReleaseAge": "5 days",
  "automerge": true,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Major bumps of production dependencies and Node need manual review",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Node major bumps need manual review",
      "matchDepNames": ["node"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ],
  "vulnerabilityAlerts": {
    "schedule": ["at any time"],
    "minimumReleaseAge": null
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update node-version in GitHub Actions workflows",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/.+\\.ya?ml$/"],
      "matchStrings": ["node-version: (?<currentValue>\\d+)"],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version",
      "versioningTemplate": "node"
    }
  ]
}
